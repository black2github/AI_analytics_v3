{
  "info": {
    "name": "Requirements Agent API",
    "description": "Коллекция запросов для тестирования LLM-агента аналитика требований",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Agent",
      "item": [
        {
          "name": "1. Get Agent Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/agent/info",
              "host": ["{{base_url}}"],
              "path": ["agent", "info"]
            },
            "description": "Получить информацию о статусе агента и текущей сессии"
          }
        },
        {
          "name": "2. Get Available Tools",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/agent/tools",
              "host": ["{{base_url}}"],
              "path": ["agent", "tools"]
            },
            "description": "Получить список доступных инструментов агента"
          }
        },
        {
          "name": "3. Chat - Simple Question",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Привет! Расскажи что ты умеешь?\",\n  \"reset_history\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/agent/chat",
              "host": ["{{base_url}}"],
              "path": ["agent", "chat"]
            },
            "description": "Простой вопрос агенту для проверки работоспособности"
          }
        },
        {
          "name": "4. Chat - Search Requirements",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Найди требования по авторизации\",\n  \"service_code\": \"SBP\",\n  \"reset_history\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/agent/chat",
              "host": ["{{base_url}}"],
              "path": ["agent", "chat"]
            },
            "description": "Поиск требований через агента (использует search_requirements tool)"
          }
        },
        {
          "name": "5. Chat - Analyze Page",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Проанализируй страницу 274628758 и дай рекомендации\",\n  \"service_code\": \"SBP\",\n  \"reset_history\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/agent/chat",
              "host": ["{{base_url}}"],
              "path": ["agent", "chat"]
            },
            "description": "Анализ конкретной страницы (использует analyze_page tool)"
          }
        },
        {
          "name": "6. Chat - Check Template",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Проверь соответствие страницы 274628758 шаблону функционального требования\",\n  \"service_code\": \"SBP\",\n  \"reset_history\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/agent/chat",
