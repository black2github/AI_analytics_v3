              "path": ["agent", "chat"]
            },
            "description": "Проверка соответствия шаблону (использует check_template_compliance tool)"
          }
        },
        {
          "name": "7. Chat - Complex Query",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Найди все нефункциональные требования к производительности и проверь есть ли среди них требования к времени отклика\",\n  \"service_code\": \"SBP\",\n  \"reset_history\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/agent/chat",
              "host": ["{{base_url}}"],
              "path": ["agent", "chat"]
            },
            "description": "Сложный запрос с несколькими шагами рассуждений"
          }
        },
        {
          "name": "8. Chat - Multi-turn Dialog",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Проанализируй первую найденную страницу детально\",\n  \"reset_history\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/agent/chat",
              "host": ["{{base_url}}"],
              "path": ["agent", "chat"]
            },
            "description": "Продолжение диалога (агент помнит контекст предыдущих сообщений)"
          }
        },
        {
          "name": "9. Reset Conversation",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/agent/reset",
              "host": ["{{base_url}}"],
              "path": ["agent", "reset"]
            },
            "description": "Сброс истории диалога"
          }
        }
      ],
      "description": "Endpoints для работы с агентом-аналитиком"
    },
